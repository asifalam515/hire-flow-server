// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
}

// ===========================================================================
// ENUMS
// ===========================================================================

enum Role {
  CANDIDATE
  RECRUITER
  ADMIN
}

enum JobStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum ApplicationStatus {
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  REJECTED
}

enum InterviewStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ===========================================================================
// MODELS
// ===========================================================================

model Company {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  field       String?
  description String? @db.Text
  logoUrl     String?

  // Relations
  users User[]
  jobs  Job[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("companies")
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String
  firstName       String?
  lastName        String?
  role            Role      @default(CANDIDATE)
  isEmailVerified Boolean   @default(false)
  otpCode         String?
  otpExpiresAt    DateTime?
  avatarUrl       String?

  // Relations
  companyId        String?
  company          Company?          @relation(fields: [companyId], references: [id], onDelete: SetNull)
  candidateProfile CandidateProfile?
  savedJobs        SavedJob[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@map("users")
}

model Job {
  id                 String    @id @default(cuid())
  title              String
  description        String?   @db.Text
  status             JobStatus @default(DRAFT)

  // Categorization
  category           String
  nature             String    // 'remote', 'hybrid', 'onsite'
  vacancies          Int?
  employmentTypes    String[]  // ['Full Time', 'Part Time', ...]
  
  // Location
  locationCountry    String
  locationCity       String
  exactAddress       String?

  // Compensation
  minSalary          Int
  maxSalary          Int
  isSalaryNegotiable Boolean   @default(false)
  benefits           String[]

  // Requirements
  educationLevel     String
  yearsOfExperience  String
  gender             String    // 'Female', 'Male', 'Any'
  candidateExperience String[] // ['Fresh Graduate', '1-2 Years', ...]
  languages          String[]
  softwareSkills     String[]
  responsibilities   String?   @db.Text
  requirements       String?   @db.Text

  // Relations
  companyId    String
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  applications Application[]
  savedJobs    SavedJob[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@map("jobs")
}

model CandidateProfile {
  id         String  @id @default(cuid())
  resumeUrl  String?
  parsedText String? @db.Text

  // Vector embedding via pgvector extension (1536 dimensions for OpenAI embeddings)
  embedding Unsupported("vector(1536)")?

  // Relations
  userId       String        @unique
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications Application[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("candidate_profiles")
}

model Application {
  id        String            @id @default(uuid())
  status    ApplicationStatus @default(APPLIED)
  version   Int               @default(1) // Optimistic concurrency control

  // Relations
  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  candidateId String
  candidate   CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  interviews  InterviewRoom[]

  // Timestamps
  appliedAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([candidateId, jobId])
  @@index([jobId])
  @@index([candidateId])
  @@map("applications")
}

model InterviewRoom {
  id              String          @id @default(cuid())
  liveKitRoomName String          @unique
  scheduledAt     DateTime
  status          InterviewStatus @default(SCHEDULED)
  recruiterNotes  String?         @db.Text

  // Relations
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([applicationId])
  @@map("interview_rooms")
}

model SavedJob {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, jobId])
  @@index([userId])
  @@index([jobId])
  @@map("saved_jobs")
}

